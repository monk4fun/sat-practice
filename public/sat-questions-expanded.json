  {"id":"math-geo-024","section":"math","topic":"geometry-trigonometry","difficulty":"medium","stem":"Supplementary angles sum to?","choices":[{"id":"A","text":"90°"},{"id":"B","text":"180°"},{"id":"C","text":"270°"},{"id":"D","text":"360°"}],"correctAnswer":"B","explanation":"Supplementary angles sum to 180°"},
