  {"id":"math-geo-022","section":"math","topic":"geometry-trigonometry","difficulty":"easy","stem":"Straight line angle is?","choices":[{"id":"A","text":"90°"},{"id":"B","text":"180°"},{"id":"C","text":"270°"},{"id":"D","text":"360°"}],"correctAnswer":"B","explanation":"Straight angle is 180°"},
