  {"id":"read-info-006","section":"reading-writing","topic":"information-and-ideas","difficulty":"easy","stimulus":"Water boils at 100°C at sea level.","stem":"What is the boiling point of water?","choices":[{"id":"A","text":"0°C"},{"id":"B","text":"50°C"},{"id":"C","text":"100°C"},{"id":"D","text":"150°C"}],"correctAnswer":"C","explanation":"The passage states 100°C"},
  {"id":"read-info-007","section":"reading-writing","topic":"information-and-ideas","difficulty":"medium","stimulus":"Photosynthesis is the process by which plants convert sunlight into chemical energy. This process produces oxygen as a byproduct.","stem":"What is a result of photosynthesis?","choices":[{"id":"A","text":"Loss of sunlight"},{"id":"B","text":"Production of oxygen"},{"id":"C","text":"Consumption of oxygen"},{"id":"D","text":"Loss of energy"}],"correctAnswer":"B","explanation":"The passage states oxygen is produced"},
  {"id":"read-info-008","section":"reading-writing","topic":"information-and-ideas","difficulty":"hard","stimulus":"Economic systems vary globally. Capitalism emphasizes private ownership, while socialism emphasizes state control. Most modern economies are mixed systems combining elements of both.","stem":"What is the main idea?","choices":[{"id":"A","text":"Capitalism is better"},{"id":"B","text":"Economic systems vary and combine different approaches"},{"id":"C","text":"Socialism is superior"},{"id":"D","text":"No mixed systems exist"}],"correctAnswer":"B","explanation":"Passage explains variation and combination of systems"},
  {"id":"read-craft-006","section":"reading-writing","topic":"craft-and-structure","difficulty":"easy","stem":"Rhetorical question purpose?","choices":[{"id":"A","text":"Expects an answer"},{"id":"B","text":"Creates emphasis without expecting answer"},{"id":"C","text":"Asks for information"},{"id":"D","text":"Shows confusion"}],"correctAnswer":"B","explanation":"Rhetorical questions emphasize a point"},
  {"id":"read-craft-007","section":"reading-writing","topic":"craft-and-structure","difficulty":"medium","stem":"What structure is this: 'Fast as lightning, the runner crossed the finish line'?","choices":[{"id":"A","text":"Simile"},{"id":"B","text":"Metaphor"},{"id":"C","text":"Alliteration"},{"id":"D","text":"Personification"}],"correctAnswer":"A","explanation":"Simile uses 'as...as' to compare"},
  {"id":"read-craft-008","section":"reading-writing","topic":"craft-and-structure","difficulty":"medium","stem":"Purpose of transition 'In conclusion'?","choices":[{"id":"A","text":"Continues ideas"},{"id":"B","text":"Contrasts ideas"},{"id":"C","text":"Signals ending"},{"id":"D","text":"Adds examples"}],"correctAnswer":"C","explanation":"'In conclusion' signals the final thought"},
  {"id":"read-craft-009","section":"reading-writing","topic":"craft-and-structure","difficulty":"hard","stem":"What does allusion provide?","choices":[{"id":"A","text":"Direct explanation"},{"id":"B","text":"Indirect reference to other works"},{"id":"C","text":"Literal description"},{"id":"D","text":"Factual information"}],"correctAnswer":"B","explanation":"Allusion is an indirect reference"},
  {"id":"read-craft-010","section":"reading-writing","topic":"craft-and-structure","difficulty":"hard","stem":"How does irony work?","choices":[{"id":"A","text":"Direct statement"},{"id":"B","text":"Opposite of expected meaning"},{"id":"C","text":"Literal meaning"},{"id":"D","text":"Question without answer"}],"correctAnswer":"B","explanation":"Irony conveys opposite of literal meaning"},
  {"id":"read-expr-006","section":"reading-writing","topic":"expression-of-ideas","difficulty":"easy","stem":"Complete idea (not fragment): 'Running in the park.'","choices":[{"id":"A","text":"Running in the park is healthy."},{"id":"B","text":"Running in the park."},{"id":"C","text":"Park runs healthy."},{"id":"D","text":"In the park, running."}],"correctAnswer":"A","explanation":"Option A is a complete sentence with subject and verb"},
  {"id":"read-expr-007","section":"reading-writing","topic":"expression-of-ideas","difficulty":"medium","stem":"Avoid run-on: 'I like reading I also like writing.'","choices":[{"id":"A","text":"I like reading I also like writing."},{"id":"B","text":"I like reading. I also like writing."},{"id":"C","text":"I like reading also writing."},{"id":"D","text":"I like reading and I also like writing"}],"correctAnswer":"B","explanation":"Period separates independent clauses"},
  {"id":"read-expr-008","section":"reading-writing","topic":"expression-of-ideas","difficulty":"medium","stem":"Misplaced modifier: Fix 'Watching the sunset, the mosquitoes bothered us.'","choices":[{"id":"A","text":"While watching the sunset, mosquitoes bothered us."},{"id":"B","text":"While we watched the sunset, mosquitoes bothered us."},{"id":"C","text":"The mosquitoes watched the sunset and bothered us."},{"id":"D","text":"Watching us, the sunset had mosquitoes."}],"correctAnswer":"B","explanation":"Modifier should clearly reference the right subject"},
  {"id":"read-expr-009","section":"reading-writing","topic":"expression-of-ideas","difficulty":"hard","stem":"Reduce wordiness: 'The reason why he left was because of rain.'","choices":[{"id":"A","text":"The reason why he left was because of rain."},{"id":"B","text":"He left because of rain."},{"id":"C","text":"The reason being rain, he left."},{"id":"D","text":"He left which was because of the rain."}],"correctAnswer":"B","explanation":"Remove redundant 'reason why' and 'because'"},
  {"id":"read-expr-010","section":"reading-writing","topic":"expression-of-ideas","difficulty":"hard","stem":"Which shows most active voice?","choices":[{"id":"A","text":"The ball was kicked by John."},{"id":"B","text":"John kicked the ball."},{"id":"C","text":"The ball was being kicked."},{"id":"D","text":"Being kicked, the ball moved."}],"correctAnswer":"B","explanation":"Active voice makes the subject perform the action"},
  {"id":"read-std-011","section":"reading-writing","topic":"standard-english-conventions","difficulty":"easy","stem":"Possessive pronoun: 'This book is _____.'","choices":[{"id":"A","text":"mine"},{"id":"B","text":"mine's"},{"id":"C","text":"my"},{"id":"D","text":"me"}],"correctAnswer":"A","explanation":"'Mine' is the possessive pronoun form"},
  {"id":"read-std-012","section":"reading-writing","topic":"standard-english-conventions","difficulty":"medium","stem":"Who vs whom: 'To _____ should I give this?'","choices":[{"id":"A","text":"who"},{"id":"B","text":"whom"},{"id":"C","text":"whose"},{"id":"D","text":"who's"}],"correctAnswer":"B","explanation":"'Whom' is the object of the preposition 'to'"},
  {"id":"read-std-013","section":"reading-writing","topic":"standard-english-conventions","difficulty":"medium","stem":"Dangling modifier: 'Running late, the car sped up.'","choices":[{"id":"A","text":"Running late, I sped up the car."},{"id":"B","text":"The car, running late, sped up."},{"id":"C","text":"The car was running and speeding up late."},{"id":"D","text":"Running late, the car was speeding."}],"correctAnswer":"A","explanation":"Modifier 'running late' should modify the subject who is running late"},
  {"id":"read-std-014","section":"reading-writing","topic":"standard-english-conventions","difficulty":"hard","stem":"Correct sequence: 'Having studied, the student took the test.'","choices":[{"id":"A","text":"Having studied, the student took the test."},{"id":"B","text":"Have studied, the student took the test."},{"id":"C","text":"Having study, the student took the test."},{"id":"D","text":"Had studying, the student took the test."}],"correctAnswer":"A","explanation":"Present participle 'having studied' shows completed action"},
  {"id":"read-std-015","section":"reading-writing","topic":"standard-english-conventions","difficulty":"hard","stem":"Verb tense consistency: 'She walks to school and took the bus home.'","choices":[{"id":"A","text":"She walks to school and took the bus home."},{"id":"B","text":"She walked to school and takes the bus home."},{"id":"C","text":"She walks to school and takes the bus home."},{"id":"D","text":"She walked to school and took the bus home."}],"correctAnswer":"C","explanation":"Use consistent present tense throughout"}
