[
  {"id":"math-geo-001","section":"math","topic":"geometry-trigonometry","difficulty":"easy","stem":"Area of rectangle: length 5, width 4?","choices":[{"id":"A","text":"9"},{"id":"B","text":"20"},{"id":"C","text":"25"},{"id":"D","text":"40"}],"correctAnswer":"B","explanation":"Area = length × width = 5 × 4 = 20"},
  {"id":"math-geo-002","section":"math","topic":"geometry-trigonometry","difficulty":"easy","stem":"Perimeter of rectangle: length 6, width 4?","choices":[{"id":"A","text":"10"},{"id":"B","text":"20"},{"id":"C","text":"24"},{"id":"D","text":"30"}],"correctAnswer":"B","explanation":"Perimeter = 2(length + width) = 2(6+4) = 20"},
  {"id":"math-geo-003","section":"math","topic":"geometry-trigonometry","difficulty":"easy","stem":"What is the area of a triangle with base 10 and height 6?","choices":[{"id":"A","text":"16"},{"id":"B","text":"30"},{"id":"C","text":"60"},{"id":"D","text":"120"}],"correctAnswer":"B","explanation":"Area = (1/2) × base × height = (1/2) × 10 × 6 = 30"},
  {"id":"math-geo-004","section":"math","topic":"geometry-trigonometry","difficulty":"easy","stem":"What is the circumference of a circle with radius 5?","choices":[{"id":"A","text":"5π"},{"id":"B","text":"10π"},{"id":"C","text":"25π"},{"id":"D","text":"50π"}],"correctAnswer":"B","explanation":"C = 2πr = 2π(5) = 10π"},
  {"id":"math-geo-005","section":"math","topic":"geometry-trigonometry","difficulty":"easy","stem":"Area of circle with radius 3?","choices":[{"id":"A","text":"3π"},{"id":"B","text":"6π"},{"id":"C","text":"9π"},{"id":"D","text":"12π"}],"correctAnswer":"C","explanation":"A = πr² = π(3)² = 9π"},
  {"id":"math-geo-006","section":"math","topic":"geometry-trigonometry","difficulty":"medium","stem":"Right triangle: legs 5 and 12. Hypotenuse?","choices":[{"id":"A","text":"13"},{"id":"B","text":"15"},{"id":"C","text":"17"},{"id":"D","text":"20"}],"correctAnswer":"A","explanation":"5² + 12² = 25 + 144 = 169 = 13²"},
  {"id":"math-geo-007","section":"math","topic":"geometry-trigonometry","difficulty":"medium","stem":"Diagonal of square with side 4?","choices":[{"id":"A","text":"4"},{"id":"B","text":"4√2"},{"id":"C","text":"8"},{"id":"D","text":"8√2"}],"correctAnswer":"B","explanation":"Diagonal = side × √2 = 4√2"},
  {"id":"math-geo-008","section":"math","topic":"geometry-trigonometry","difficulty":"medium","stem":"Volume of rectangular box: length 4, width 3, height 5?","choices":[{"id":"A","text":"12"},{"id":"B","text":"35"},{"id":"C","text":"60"},{"id":"D","text":"120"}],"correctAnswer":"C","explanation":"Volume = length × width × height = 4 × 3 × 5 = 60"},
  {"id":"math-geo-009","section":"math","topic":"geometry-trigonometry","difficulty":"medium","stem":"Area of trapezoid: bases 4 and 6, height 3?","choices":[{"id":"A","text":"15"},{"id":"B","text":"18"},{"id":"C","text":"30"},{"id":"D","text":"36"}],"correctAnswer":"A","explanation":"A = (1/2)(b₁ + b₂)h = (1/2)(4+6)(3) = 15"},
  {"id":"math-geo-010","section":"math","topic":"geometry-trigonometry","difficulty":"medium","stem":"Distance between (0,0) and (3,4)?","choices":[{"id":"A","text":"3"},{"id":"B","text":"4"},{"id":"C","text":"5"},{"id":"D","text":"7"}],"correctAnswer":"C","explanation":"d = √(3² + 4²) = √(9+16) = √25 = 5"},
  {"id":"math-geo-011","section":"math","topic":"geometry-trigonometry","difficulty":"hard","stem":"Angles in triangle sum to?","choices":[{"id":"A","text":"90°"},{"id":"B","text":"180°"},{"id":"C","text":"270°"},{"id":"D","text":"360°"}],"correctAnswer":"B","explanation":"The sum of angles in any triangle is 180°"},
  {"id":"math-geo-012","section":"math","topic":"geometry-trigonometry","difficulty":"hard","stem":"In triangle: one angle 60°, another 80°. Third?","choices":[{"id":"A","text":"30°"},{"id":"B","text":"40°"},{"id":"C","text":"50°"},{"id":"D","text":"60°"}],"correctAnswer":"B","explanation":"60° + 80° + x = 180°; x = 40°"},
  {"id":"math-geo-013","section":"math","topic":"geometry-trigonometry","difficulty":"hard","stem":"If triangle has sides 3, 4, 5, it's?","choices":[{"id":"A","text":"Acute"},{"id":"B","text":"Right"},{"id":"C","text":"Obtuse"},{"id":"D","text":"Equilateral"}],"correctAnswer":"B","explanation":"3² + 4² = 9 + 16 = 25 = 5², so it's a right triangle"},
  {"id":"math-geo-014","section":"math","topic":"geometry-trigonometry","difficulty":"hard","stem":"Surface area of cube with side 2?","choices":[{"id":"A","text":"8"},{"id":"B","text":"12"},{"id":"C","text":"24"},{"id":"D","text":"32"}],"correctAnswer":"C","explanation":"6 faces, each area 2² = 4; total = 6 × 4 = 24"},
  {"id":"math-geo-015","section":"math","topic":"geometry-trigonometry","difficulty":"hard","stem":"Two parallel lines cut by transversal. Alternate interior angles?","choices":[{"id":"A","text":"Different"},{"id":"B","text":"Equal"},{"id":"C","text":"Supplementary"},{"id":"D","text":"Complementary"}],"correctAnswer":"B","explanation":"Alternate interior angles formed by parallel lines are equal"},
  {"id":"math-geo-016","section":"math","topic":"geometry-trigonometry","difficulty":"easy","stem":"Circumference of circle with diameter 10?","choices":[{"id":"A","text":"5π"},{"id":"B","text":"10π"},{"id":"C","text":"20π"},{"id":"D","text":"100π"}],"correctAnswer":"B","explanation":"C = πd = π(10) = 10π"},
  {"id":"math-geo-017","section":"math","topic":"geometry-trigonometry","difficulty":"medium","stem":"Area of equilateral triangle with side 4?","choices":[{"id":"A","text":"4"},{"id":"B","text":"8"},{"id":"C","text":"4√3"},{"id":"D","text":"8√3"}],"correctAnswer":"C","explanation":"A = (√3/4)s² = (√3/4)(16) = 4√3"},
  {"id":"math-geo-018","section":"math","topic":"geometry-trigonometry","difficulty":"medium","stem":"Angles in quadrilateral sum to?","choices":[{"id":"A","text":"180°"},{"id":"B","text":"270°"},{"id":"C","text":"360°"},{"id":"D","text":"450°"}],"correctAnswer":"C","explanation":"Sum of angles in quadrilateral is 360°"},
  {"id":"math-geo-019","section":"math","topic":"geometry-trigonometry","difficulty":"hard","stem":"Regular hexagon with side 2. Area?","choices":[{"id":"A","text":"6√3"},{"id":"B","text":"12√3"},{"id":"C","text":"24"},{"id":"D","text":"48"}],"correctAnswer":"A","explanation":"Area = (3√3/2)s² = (3√3/2)(4) = 6√3"},
  {"id":"math-geo-020","section":"math","topic":"geometry-trigonometry","difficulty":"hard","stem":"Sphere radius 3. Volume?","choices":[{"id":"A","text":"27π"},{"id":"B","text":"36π"},{"id":"C","text":"81π"},{"id":"D","text":"108π"}],"correctAnswer":"B","explanation":"V = (4/3)πr³ = (4/3)π(27) = 36π"},
  {"id":"read-info-001","section":"reading-writing","topic":"information-and-ideas","difficulty":"easy","stimulus":"The sun rises in the east and sets in the west every day.","stem":"What pattern is described?","choices":[{"id":"A","text":"Irregular movement"},{"id":"B","text":"Daily pattern"},{"id":"C","text":"No pattern"},{"id":"D","text":"Seasonal change"}],"correctAnswer":"B","explanation":"Every day is a repeating daily pattern"},
  {"id":"read-info-002","section":"reading-writing","topic":"information-and-ideas","difficulty":"easy","stimulus":"Plants need water, sunlight, and soil to grow.","stem":"What are the requirements for plant growth?","choices":[{"id":"A","text":"Just water"},{"id":"B","text":"Just sunlight"},{"id":"C","text":"Water, sunlight, and soil"},{"id":"D","text":"Water and soil only"}],"correctAnswer":"C","explanation":"The passage lists all three requirements"},
  {"id":"read-info-003","section":"reading-writing","topic":"information-and-ideas","difficulty":"medium","stimulus":"Climate change is caused by increased greenhouse gases in the atmosphere. These gases trap heat, causing rising temperatures. This affects weather patterns and ecosystems.","stem":"What is the chain of effects described?","choices":[{"id":"A","text":"Greenhouse gases → heat trapping → temperature rise"},{"id":"B","text":"Weather changes → temperature rise"},{"id":"C","text":"Ecosystems → greenhouse gases"},{"id":"D","text":"Temperature rise → greenhouse gases"}],"correctAnswer":"A","explanation":"The passage shows greenhouse gases cause heat trapping which causes temperature rise"},
  {"id":"read-info-004","section":"reading-writing","topic":"information-and-ideas","difficulty":"medium","stimulus":"The Renaissance began in Italy in the 14th century. It spread to other European countries over centuries. It marked transition from medieval to modern thinking.","stem":"What was the geographical origin?","choices":[{"id":"A","text":"France"},{"id":"B","text":"Germany"},{"id":"C","text":"Italy"},{"id":"D","text":"Spain"}],"correctAnswer":"C","explanation":"The passage states it began in Italy"},
  {"id":"read-info-005","section":"reading-writing","topic":"information-and-ideas","difficulty":"hard","stimulus":"The scientific method involves observation, hypothesis formation, experimentation, and analysis. Each step builds on the previous one to test ideas systematically.","stem":"What is emphasized about the scientific method?","choices":[{"id":"A","text":"It's disorganized"},{"id":"B","text":"Steps are random"},{"id":"C","text":"Each step builds on previous work systematically"},{"id":"D","text":"It relies on guessing"}],"correctAnswer":"C","explanation":"Passage emphasizes systematic building through sequential steps"},
  {"id":"read-craft-001","section":"reading-writing","topic":"craft-and-structure","difficulty":"easy","stem":"What tone is conveyed: 'The results were disappointing'?","choices":[{"id":"A","text":"Excited"},{"id":"B","text":"Negative"},{"id":"C","text":"Uncertain"},{"id":"D","text":"Happy"}],"correctAnswer":"B","explanation":"'Disappointing' conveys a negative tone"},
  {"id":"read-craft-002","section":"reading-writing","topic":"craft-and-structure","difficulty":"medium","stem":"What does an exclamation point primarily add?","choices":[{"id":"A","text":"Emphasis and emotion"},{"id":"B","text":"Confusion"},{"id":"C","text":"Questions"},{"id":"D","text":"Information"}],"correctAnswer":"A","explanation":"Exclamation points convey emphasis and strong emotion"},
  {"id":"read-craft-003","section":"reading-writing","topic":"craft-and-structure","difficulty":"medium","stem":"How does this affect tone: 'The meeting was, unfortunately, postponed'?","choices":[{"id":"A","text":"No effect"},{"id":"B","text":"Adds regret or disappointment"},{"id":"C","text":"Adds excitement"},{"id":"D","text":"Adds confusion"}],"correctAnswer":"B","explanation":"'Unfortunately' signals regret about the postponement"},
  {"id":"read-craft-004","section":"reading-writing","topic":"craft-and-structure","difficulty":"hard","stem":"What structure best shows contrast?","choices":[{"id":"A","text":"Similarly..."},{"id":"B","text":"However..."},{"id":"C","text":"Furthermore..."},{"id":"D","text":"Therefore..."}],"correctAnswer":"B","explanation":"'However' signals contrast or contradiction"},
  {"id":"read-craft-005","section":"reading-writing","topic":"craft-and-structure","difficulty":"hard","stem":"Identify the transition: 'First we observed. _____, we analyzed data.'","choices":[{"id":"A","text":"Similarly"},{"id":"B","text":"Next"},{"id":"C","text":"However"},{"id":"D","text":"Therefore"}],"correctAnswer":"B","explanation":"'Next' shows sequence of steps"},
  {"id":"read-expr-001","section":"reading-writing","topic":"expression-of-ideas","difficulty":"easy","stem":"Which is clearest: (A) 'The book by John was good' or (B) 'John's book was good'?","choices":[{"id":"A","text":"(A) is clearer"},{"id":"B","text":"(B) is clearer"},{"id":"C","text":"Both equally clear"},{"id":"D","text":"(A) is shorter"}],"correctAnswer":"B","explanation":"(B) is more concise and equally clear"},
  {"id":"read-expr-002","section":"reading-writing","topic":"expression-of-ideas","difficulty":"medium","stem":"Improve: 'The report that was written by the team was important'","choices":[{"id":"A","text":"The team's important report was written"},{"id":"B","text":"The team wrote an important report"},{"id":"C","text":"The report was written by the team which was important"},{"id":"D","text":"The important report being written was by the team"}],"correctAnswer":"B","explanation":"More concise and clearer sentence structure"},
  {"id":"read-expr-003","section":"reading-writing","topic":"expression-of-ideas","difficulty":"medium","stem":"Which revision improves flow?","choices":[{"id":"A","text":"The student studied hard. The student took the test. The student passed."},{"id":"B","text":"The student studied hard, took the test, and passed."},{"id":"C","text":"The student being hard-studying took the test passed"},{"id":"D","text":"The student, studying hard, the test, passing it"}],"correctAnswer":"B","explanation":"Using parallel structure with conjunctions improves flow"},
  {"id":"read-expr-004","section":"reading-writing","topic":"expression-of-ideas","difficulty":"hard","stem":"What makes this wordy: 'There are many students who believe that tests are important'?","choices":[{"id":"A","text":"Too many commas"},{"id":"B","text":"'There are' construction is passive"},{"id":"C","text":"Wrong tense"},{"id":"D","text":"Too many adjectives"}],"correctAnswer":"B","explanation":"Direct version: 'Many students believe tests are important'"},
  {"id":"read-expr-005","section":"reading-writing","topic":"expression-of-ideas","difficulty":"hard","stem":"Combine sentences best: 'The sun is bright. It warms the earth.'","choices":[{"id":"A","text":"The sun is bright and it warms the earth"},{"id":"B","text":"The bright sun warms the earth"},{"id":"C","text":"The sun is bright, and moreover, warms the earth"},{"id":"D","text":"The sun being bright warms the earth"}],"correctAnswer":"B","explanation":"Most concise and clear combination"},
  {"id":"read-std-001","section":"reading-writing","topic":"standard-english-conventions","difficulty":"easy","stem":"Correct form: 'She _____ to the store yesterday.'","choices":[{"id":"A","text":"go"},{"id":"B","text":"goes"},{"id":"C","text":"went"},{"id":"D","text":"going"}],"correctAnswer":"C","explanation":"Past tense 'went' matches 'yesterday'"},
  {"id":"read-std-002","section":"reading-writing","topic":"standard-english-conventions","difficulty":"easy","stem":"Choose correct pronoun: 'He gave the book to _____ (I/me)'","choices":[{"id":"A","text":"I"},{"id":"B","text":"me"},{"id":"C","text":"myself"},{"id":"D","text":"moi"}],"correctAnswer":"B","explanation":"After preposition 'to', use object pronoun 'me'"},
  {"id":"read-std-003","section":"reading-writing","topic":"standard-english-conventions","difficulty":"easy","stem":"Correct: 'The dogs _____ (is/are) playing.'","choices":[{"id":"A","text":"is"},{"id":"B","text":"are"},{"id":"C","text":"were"},{"id":"D","text":"be"}],"correctAnswer":"B","explanation":"Plural 'dogs' requires plural verb 'are'"},
  {"id":"read-std-004","section":"reading-writing","topic":"standard-english-conventions","difficulty":"medium","stem":"Fix: 'Between you and I, the answer is wrong.'","choices":[{"id":"A","text":"Between you and me"},{"id":"B","text":"Between you and I"},{"id":"C","text":"Among you and me"},{"id":"D","text":"No change needed"}],"correctAnswer":"A","explanation":"After 'between', use object pronoun 'me'"},
  {"id":"read-std-005","section":"reading-writing","topic":"standard-english-conventions","difficulty":"medium","stem":"Subject-verb agreement: 'The team _____ (is/are) ready.'","choices":[{"id":"A","text":"is"},{"id":"B","text":"are"},{"id":"C","text":"were"},{"id":"D","text":"be"}],"correctAnswer":"A","explanation":"'Team' is singular, so use singular verb 'is'"},
  {"id":"read-std-006","section":"reading-writing","topic":"standard-english-conventions","difficulty":"medium","stem":"Correct comma usage: 'I like apples oranges and bananas.'","choices":[{"id":"A","text":"apples, oranges and bananas"},{"id":"B","text":"apples oranges, and bananas"},{"id":"C","text":"apples, oranges, and bananas"},{"id":"D","text":"apples oranges and bananas (correct)"}],"correctAnswer":"C","explanation":"Use commas in series (Oxford comma recommended)"},
  {"id":"read-std-007","section":"reading-writing","topic":"standard-english-conventions","difficulty":"hard","stem":"Subjunctive mood: 'If I _____ (was/were) president...'","choices":[{"id":"A","text":"was"},{"id":"B","text":"were"},{"id":"C","text":"am"},{"id":"D","text":"be"}],"correctAnswer":"B","explanation":"Subjunctive uses 'were' for hypothetical conditions"},
  {"id":"read-std-008","section":"reading-writing","topic":"standard-english-conventions","difficulty":"hard","stem":"Parallel structure: 'I like reading, _____, and swimming.'","choices":[{"id":"A","text":"to write"},{"id":"B","text":"writing"},{"id":"C","text":"written"},{"id":"D","text":"write"}],"correctAnswer":"B","explanation":"Gerunds must be parallel: reading, writing, swimming"},
